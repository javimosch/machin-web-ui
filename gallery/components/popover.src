// popover.src — click-toggled floating panel, no JS: native <details> with an
// absolutely-positioned body. Like dropdown but for arbitrary content.

func ui_popover(trigger, body) (h) {
    h = "<details class=\"relative inline-block\">"
    h = h + "<summary class=\"inline-flex cursor-pointer items-center gap-2 rounded-md border border-stone-200 bg-white px-4 py-2 text-sm font-medium hover:bg-stone-100\">" + ui_esc(trigger) + "</summary>"
    h = h + "<div class=\"absolute left-0 z-10 mt-1 w-72 max-w-full rounded-lg border border-stone-200 bg-white p-4 text-sm leading-6 text-stone-500\">" + body + "</div>"
    h = h + "</details>"
}
