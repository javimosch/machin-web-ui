// textarea.src — multi-line input styled to match ui_input. `rows` is the
// visible line count.

func ui_textarea(name, placeholder, rows, value) (h) {
    h = "<textarea class=\"w-full rounded-md border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 px-3 py-2 text-sm text-stone-900 dark:text-stone-100 placeholder:text-stone-400 dark:placeholder:text-stone-500 focus:outline-none focus:ring-2 focus:ring-stone-300 dark:focus:ring-stone-600 focus:border-stone-300 dark:focus:border-stone-600\" name=\"" + name + "\" rows=\"" + str(rows) + "\""
    if len(placeholder) > 0 { h = h + " placeholder=\"" + ui_esc(placeholder) + "\"" }
    h = h + ">" + ui_esc(value) + "</textarea>"
}
