// twgen.src — spike CLI: read whitespace-separated class names on stdin,
// emit the Tailwind-compatible stylesheet on stdout.
func main() {
    raw := read_stdin()
    classes := []string{}
    for _, line := range split(raw, "\n") {
        for _, c := range split(trim(line), " ") {
            t := trim(c)
            if len(t) > 0 { classes = append(classes, t) }
        }
    }
    print(tw_css(classes))
}
