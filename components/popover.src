// popover.src — click-toggled floating panel, no JS: native <details> with an
// absolutely-positioned body. Like dropdown but for arbitrary content.

func ui_popover(trigger, body) (h) {
    h = "<details class=\"relative inline-block\">"
    h = h + "<summary class=\"inline-flex cursor-pointer items-center gap-2 rounded-md border border-line dark:border-line-800 bg-surface dark:bg-surface-900 px-4 py-2 text-sm font-medium hover:bg-surface-100 dark:hover:bg-surface-800\">" + ui_esc(trigger) + "</summary>"
    h = h + "<div class=\"absolute left-0 z-10 mt-1 w-72 max-w-full rounded-lg border border-line dark:border-line-800 bg-surface dark:bg-surface-900 p-4 text-sm leading-6 text-muted dark:text-muted-400\">" + body + "</div>"
    h = h + "</details>"
}
