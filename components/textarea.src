// textarea.src — multi-line input styled to match ui_input. `rows` is the
// visible line count.

func ui_textarea(name, placeholder, rows, value) (h) {
    h = "<textarea class=\"w-full rounded-md border border-line dark:border-line-800 bg-surface dark:bg-surface-900 px-3 py-2 text-sm text-ink dark:text-ink-100 placeholder:text-muted-400 dark:placeholder:text-muted-500 focus:outline-none focus:ring-2 focus:ring-line-300 dark:focus:ring-line-600 focus:border-line-300 dark:focus:border-line-600\" name=\"" + name + "\" rows=\"" + str(rows) + "\""
    if len(placeholder) > 0 { h = h + " placeholder=\"" + ui_esc(placeholder) + "\"" }
    h = h + ">" + ui_esc(value) + "</textarea>"
}
